    "landmarks": {
      "ear": "Side-of-head landmark (MediaPipe Pose #7 or #8)",
      "shoulder": "Shoulder landmark (MediaPipe Pose #11 or #12)",
      "elbow": "Elbow landmark (MediaPipe Pose #13 or #14)",
      "wrist": "Wrist landmark (MediaPipe Pose #15 or #16)",
      "index_mcp": "Index finger MCP knuckle (MediaPipe Hand #5)",
      "pinky_mcp": "Pinky finger MCP knuckle (MediaPipe Hand #17)"
    },
    "labels": ["Safe", "High Strain"]
  },
